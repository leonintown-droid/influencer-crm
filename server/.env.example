# ============================================================
#  红人营销 CRM 后端环境变量模板
#  复制为 .env 并填入真实凭证。留空的功能会自动降级（仍可本地运行）。
# ============================================================

# ---- 服务 ----
PORT=8787
SESSION_SECRET=change-me-to-a-long-random-string

# ---- 数据后端：飞书多维表格 Base ----
# 留空则使用本地 JSON 文件做数据库（data/db.json），CRM 仍可完整运行。
# 填入后，所有 CRUD 自动走飞书 Base（前端永不直连，密钥仅服务端持有）。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_TOKEN=
# 各数据表 table_id（在 Base 内每张表 URL 的 table= 参数里）
FEISHU_TABLE_INFLUENCERS=
FEISHU_TABLE_PUBLIC=
FEISHU_TABLE_CAMPAIGNS=
FEISHU_TABLE_OUTPUTS=
FEISHU_TABLE_USERS=
FEISHU_TABLE_EMAILS=
FEISHU_TABLE_NOTIFS=
FEISHU_TABLE_TEMPLATES=
FEISHU_TABLE_SETTINGS=

# ---- 导出目标 Base（功能7）----
EXPORT_BASE_TOKEN=

# ---- Gmail / Google Workspace OAuth（功能1）----
# 留空则邮件功能降级为"仅生成模板 + 手动记录"。
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8787/api/email/oauth/callback

# ---- 第三方爬虫数据 API（功能4/5）----
# 留空则爬虫使用内置模拟数据生成器演示完整流程。
CRAWLER_PROVIDER=mock
CRAWLER_API_KEY=
CRAWLER_API_HOST=

# ---- 定时任务 cron 表达式 ----
CRON_CRAWLER=0 3 * * *
CRON_SLA=*/30 * * * *
